@attribute [StreamRendering]

<p class="text-muted">Manage your media profiles and configurations. Each profile can have its own set of directories
    and scanning rules.</p>
@if (Profiles.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No profiles found. Click "Add Profile" to create one.
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var profile in Profiles)
        {
            <div class="border rounded p-3">
                <div class="d-flex align-items-start gap-3 mb-2 flex-wrap">
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-sliders text-primary"></i>
                            <h5 class="mb-0">@profile.Name</h5>
                        </div>
                        <div class="small">
                            <DirectoryDisplay Directories="profile.Directories"/>
                        </div>
                    </div>
                    <div class="d-flex gap-1">
                        <a class="btn btn-sm btn-outline-primary"
                           href="/settings/profile/@profile.Id">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => CloneProfile(profile)">
                            <i class="bi bi-copy"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => DeleteProfile(profile)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                    <ToolTip Tip="Audio rules">
                        <i class="bi bi-volume-up text-muted" style="width: 18px;"></i>
                    </ToolTip>
                    <TrackSettingsDisplay Settings="@profile.AudioSettings"/>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <ToolTip Tip="Subtitle rules">
                        <i class="bi bi-badge-cc text-muted" style="width: 18px;"></i>
                    </ToolTip>
                    <TrackSettingsDisplay Settings="@profile.SubtitleSettings"/>
                </div>

                @if (profile.ClearVideoTrackNames || profile.SkipHardlinkedFiles)
                {
                    <div class="d-flex align-items-center gap-2 mt-2 pt-2 border-top">
                        @if (profile.ClearVideoTrackNames)
                        {
                            <ToolTip Tip="Video track names will be cleared during conversion">
                                <span class="badge text-bg-light border">
                                    <i class="bi bi-film me-1"></i>Clear video names
                                </span>
                            </ToolTip>
                        }
                        @if (profile.SkipHardlinkedFiles)
                        {
                            <ToolTip Tip="Files with hard links are skipped during scanning and conversion">
                                <span class="badge text-bg-light border">
                                    <i class="bi bi-link-45deg me-1"></i>Skip hardlinked
                                </span>
                            </ToolTip>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
<StickyBar>
    <a class="btn btn-primary" href="/settings/profile/new">
        <i class="bi bi-plus-lg me-2"></i>Add Profile
    </a>
</StickyBar>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [CascadingParameter] public required IModalService Modal { get; set; }

    private List<Profile> Profiles { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        Profiles = await context.Profiles.ToListAsync().ConfigureAwait(false);
    }

    private async Task CloneProfile(Profile profile)
    {
        if (!await Modal.ShowConfirm($"Clone profile '{profile.Name}'?"))
        {
            return;
        }

        var clone = profile.Clone();
        clone.Id = 0;
        clone.Name = $"{profile.Name} (Copy)";

        await using var context = await ContextFactory.CreateDbContextAsync();
        context.Add(clone);
        await context.SaveChangesAsync();
        Profiles.Add(clone);

        ToastService.ShowSuccess($"Profile '{clone.Name}' created.");
    }

    private async Task DeleteProfile(Profile profile)
    {
        if (!await Modal.ShowConfirm($"Delete profile '{profile.Name}'? All scanned media files linked to this profile will be removed from Muxarr. Your actual media files on disk are never touched."))
        {
            return;
        }

        await using var context = await ContextFactory.CreateDbContextAsync();

        Profiles.Remove(profile);
        if (profile.Id > 0)
        {
            await context.Profiles.Where(x => x.Id == profile.Id).ExecuteDeleteAsync();
            await context.SaveChangesAsync();
        }

        ToastService.ShowWarning($"Profile '{profile.Name}' deleted.");
    }

}
